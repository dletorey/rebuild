<template webc:type="11ty" 11ty:type="njk, md">
{% set heading = album %}
{% if type === "album" %}
### Album {{ heading }}
{% elseif type === "photo" %}
### Photo {{ heading }}
{% elseif type === "video" %}
### Video {{ heading }}
{% endif %}
hello Flickr <span alt="{{name}}">{{name}} - {{album}}</span>
</template>